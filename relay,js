export default {
  async fetch(request) {
    const url = new URL(request.url);

    // CORS preflight
    if (request.method === "OPTIONS") {
      return new Response(null, {
        headers: {
          "Access-Control-Allow-Origin": "*",
          "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
          "Access-Control-Allow-Headers": "*",
        }
      });
    }

    let encoded = url.searchParams.get("url");
    if (!encoded) return new Response("sem url", { status: 400 });

    let targetUrl;
    try {
      targetUrl = atob(encoded);
    } catch {
      return new Response("url inválida", { status: 400 });
    }

    try {
      const targetObj = new URL(targetUrl);
      const reqHeaders = {};

      // Repassa headers que o prox.js enviou (incluindo Content-Type e chaves de API)
      for (const [key, value] of request.headers.entries()) {
        const k = key.toLowerCase();
        // Evita headers que podem causar conflito de host ou segurança do worker
        if (!["host", "connection", "cf-ray", "x-forwarded-for"].includes(k)) {
          reqHeaders[key] = value;
        }
      }

      // Sobrescreve/Garante os headers de identidade para o alvo
      reqHeaders["Origin"] = targetObj.origin;
      reqHeaders["Referer"] = targetObj.origin + "/";
      reqHeaders["Host"] = targetObj.host;

      // Ajuste de cookie vindo do proxy
      const relayCookie = request.headers.get("x-relay-cookie");
      if (relayCookie) reqHeaders["Cookie"] = relayCookie;

      const response = await fetch(targetUrl, {
        method: request.method,
        headers: reqHeaders,
        body: ["GET", "HEAD"].includes(request.method) ? null : await request.arrayBuffer(),
        redirect: "follow"
      });

      const resHeaders = new Headers();
      const allowedHeaders = ["content-type", "cache-control", "expires", "last-modified", "etag"];

      for (const h of allowedHeaders) {
        const val = response.headers.get(h);
        if (val) resHeaders.set(h, val);
      }

      resHeaders.set("Access-Control-Allow-Origin", "*");
      resHeaders.set("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS");
      resHeaders.set("Access-Control-Allow-Headers", "*");

      const setCookie = response.headers.get("set-cookie");
      if (setCookie) resHeaders.set("x-relay-set-cookie", setCookie);

      return new Response(response.body, {
        status: response.status,
        headers: resHeaders
      });

    } catch (err) {
      return new Response("relay erro: " + err.message, { status: 500 });
    }
  }
};